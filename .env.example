# Slapture Environment Configuration

# Anthropic API key for Mastermind and Evolver LLM calls
ANTHROPIC_API_KEY=your-api-key-here

# Server configuration
PORT=3000
DATA_DIR=./data
FILESTORE_DIR=./filestore

# intend.do OAuth (Phase 2)
# Register your app at intend.do to get client credentials
INTEND_CLIENT_ID=your-client-id
INTEND_CLIENT_SECRET=your-client-secret
INTEND_BASE_URL=https://intend.do
CALLBACK_BASE_URL=http://localhost:3000

# Storage backend: 'local' (default) or 'firestore'
STORAGE_BACKEND=local

# Firebase (required when STORAGE_BACKEND=firestore)
# Run scripts/setup-firebase.sh to create a project and generate credentials
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Google Sheets integration (optional)
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=

# For E2E tests with test credentials
INTEND_TEST_URL=https://intend.do
