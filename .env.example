# Slapture Environment Configuration

# Anthropic API key for Mastermind and Evolver LLM calls
ANTHROPIC_API_KEY=your-api-key-here

# Server configuration
PORT=3000
DATA_DIR=./data
FILESTORE_DIR=./filestore

# intend.do OAuth (Phase 2)
# Register your app at intend.do to get client credentials
INTEND_CLIENT_ID=your-client-id
INTEND_CLIENT_SECRET=your-client-secret
INTEND_BASE_URL=https://intend.do
CALLBACK_BASE_URL=http://localhost:3000

# For E2E tests with test credentials
INTEND_TEST_URL=https://intend.do
